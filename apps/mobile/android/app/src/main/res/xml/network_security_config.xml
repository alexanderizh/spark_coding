<?xml version="1.0" encoding="utf-8"?>
<!--
  Network security configuration that allows cleartext HTTP traffic to
  localhost and private network ranges during development.

  In production, traffic should always use HTTPS/WSS.
  Remove or restrict the cleartext-traffic-permitted entries for release builds.
-->
<network-security-config>
    <!-- Allow cleartext for localhost development -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">10.0.0.0/8</domain>
        <domain includeSubdomains="true">192.168.0.0/16</domain>
        <domain includeSubdomains="true">172.16.0.0/12</domain>
    </domain-config>

    <!-- All other domains must use HTTPS -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
